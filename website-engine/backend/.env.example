# Which config file to load (must match a file in configs/)
CLIENT_ID=clinic

# Path to the configs directory (default: ./configs)
CONFIG_DIR=./configs

# Comma-separated allowed CORS origins
# Dev: leave as localhost; Prod: set to the actual frontend URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment: dev | prod
ENV=dev

# SMTP settings — leave blank to fall back to console logging in dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
