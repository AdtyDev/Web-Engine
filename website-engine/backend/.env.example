# ─────────────────────────────────────────────────────────────────────────────
# website-engine — backend environment variables
# Copy this file to .env and fill in values for your environment.
# Never commit a real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────

# Which JSON config to load from ./configs/
CLIENT_ID=clinic

# "dev" → enables ?client= override endpoint, logs emails to console.
# Any other value (e.g. "prod") enables production guard-rails.
ENV=dev

# Absolute or relative path to the directory containing <client>.json configs.
CONFIG_DIR=./configs

# Comma-separated list of frontend origins allowed for CORS.
# In prod (same-origin nginx setup): leave blank or remove.
# In prod (separate frontend domain): set to https://yourdomain.com
ALLOWED_ORIGINS_RAW=http://localhost:5173,http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────

# Max contact-form submissions from a single IP within the window.
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_SECONDS=60

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Set ALL five of SMTP_HOST / SMTP_USER / SMTP_PASS / SMTP_FROM / SMTP_TO
# to enable email delivery. If any are missing, submissions are logged to
# the console instead (safe dev default — no emails lost, just not delivered).
#
# SMTP_PORT defaults to 587 (STARTTLS). For port 465 (SSL/TLS), also set SMTP_SSL=true.
# SMTP_TIMEOUT is the connection timeout in seconds (default 10).
#
# ── Gmail / Google Workspace ──────────────────────────────────────────────────
# Requires an App Password (not your normal password).
# Create one at: https://myaccount.google.com/apppasswords
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SSL=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx   # App Password (16-char, no spaces)
# SMTP_FROM=You Name <you@gmail.com>
# SMTP_TO=recipient@example.com
#
# ── SendGrid ─────────────────────────────────────────────────────────────────
# Create a free account at sendgrid.com, verify a sender domain,
# generate an API key (Mail Send permission), then:
#
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SSL=false
# SMTP_USER=apikey               # Literal string "apikey" — not your email
# SMTP_PASS=SG.xxxxxxxxxxxx      # Your SendGrid API key
# SMTP_FROM=noreply@yourdomain.com
# SMTP_TO=inbox@yourdomain.com
#
# ── Mailgun ───────────────────────────────────────────────────────────────────
#
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SSL=false
# SMTP_USER=postmaster@sandbox<id>.mailgun.org
# SMTP_PASS=<mailgun-smtp-password>
# SMTP_FROM=noreply@yourdomain.com
# SMTP_TO=inbox@yourdomain.com
#
# ── Amazon SES ────────────────────────────────────────────────────────────────
# Requires a verified domain. Get SMTP credentials from the SES console.
#
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_SSL=false
# SMTP_USER=<SES SMTP Access Key ID>
# SMTP_PASS=<SES SMTP Secret Access Key>
# SMTP_FROM=noreply@yourdomain.com
# SMTP_TO=inbox@yourdomain.com
#
# ── Postmark ──────────────────────────────────────────────────────────────────
#
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_SSL=false
# SMTP_USER=<Server API Token>
# SMTP_PASS=<Server API Token>       # Same value as SMTP_USER for Postmark
# SMTP_FROM=noreply@yourdomain.com
# SMTP_TO=inbox@yourdomain.com

SMTP_HOST=
SMTP_PORT=587
SMTP_SSL=false
SMTP_TIMEOUT=10
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
